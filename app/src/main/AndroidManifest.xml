<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- A device that has any camera be it front, back or external will work. -->
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="true" />
    <!-- TrueSnap captures only via its own camera — no gallery import.
         Strip all storage/media-read permissions that library manifests
         would otherwise merge into the final APK. -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_VIDEO"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_AUDIO"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        tools:node="remove" />
    <!-- Needed for MediaStore.Images writes on Android 9 (API 28, our minSdk) only.
         API 29+ writes to MediaStore without this permission. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission
        android:name="android.permission.ACCESS_MEDIA_LOCATION"
        tools:node="remove" />

    <uses-permission
        android:name="android.permission.ACCESS_COARSE_LOCATION"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        tools:node="remove" />

    <uses-permission
        android:name="android.permission.CAMERA"
        tools:remove="android:maxSdkVersion" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <uses-permission
        android:name="android.permission.ACCESS_NETWORK_STATE"
        tools:remove="android:maxSdkVersion" />
    <uses-permission
        android:name="android.permission.INTERNET"
        tools:remove="android:maxSdkVersion" />
    <uses-permission
        android:name="android.permission.READ_PHONE_STATE"
        tools:remove="android:maxSdkVersion" />

    <uses-permission android:name="android.permission.GET_ACCOUNTS" />

    <uses-permission android:name="android.permission.DETECT_SCREEN_CAPTURE" />
    <uses-permission android:name="android.permission.DETECT_SCREEN_RECORDING" />

    <application
        android:name=".ProofModeApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity android:name=".PermissionActivity" />
        <activity
            android:name=".onboarding.OnboardingActivity"
            android:label="@string/app_name" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleInstance">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>
        <activity
            android:name=".SettingsActivity"
            android:label="@string/activity_settings_title" />
        <activity
            android:name=".SigningSettingsActivity"
            android:label="@string/settings_signing_title"/>
        <activity
            android:name=".NotarySettingsActivity"
            android:label="@string/notary_settings_title" />
        <activity
            android:name=".NostrIdentityActivity"
            android:label="@string/nostr_identity_title" />
        <activity
            android:name=".org.witness.proofmode.ui.DataLegendActivity"
            android:label="@string/activity_datalegend_title" />
        <activity
            android:name=".org.witness.proofmode.ui.DigitalSignaturesActivity"
            android:label="@string/menu_digital_signatures" />
        <activity
            android:name=".org.witness.proofmode.share.FilebaseSettingsActivity"
            android:label="@string/auto_sync_title" />

        <receiver
            android:name=".org.witness.proofmode.util.OnBootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>
        <!--
            MediaWatcher is intentionally not declared as a manifest receiver.
            It is constructed and held as an in-process singleton via
            MediaWatcher.getInstance(context); the in-app camera path calls
            ingestMedia() on that instance directly. Exposing it via a
            manifest <receiver> entry would let any installed app cause the
            user's PGP identity to vouch for attacker-supplied content.
        -->

<activity
            android:name=".org.witness.proofmode.share.ShareProofActivity"
            android:exported="false"
            android:label="@string/share_proof_action"
            android:launchMode="singleTop" />
        <activity
            android:name=".VerifyProofActivity"
            android:exported="false"
            android:label="@string/verify_proof"
            android:theme="@style/AppTheme.NoActionBar" />

        <service
            android:name=".service.PhotosContentJob"
            android:exported="true"
            android:permission="android.permission.BIND_JOB_SERVICE" />
        <service
            android:name=".service.VideosContentJob"
            android:exported="true"
            android:permission="android.permission.BIND_JOB_SERVICE" />

        <!--
            CameraEventReceiver hooks the long-deprecated NEW_PICTURE/NEW_VIDEO
            broadcasts (removed from AOSP camera apps in API 24+, app minSdk
            is 28). Its onReceive() is effectively a no-op today, but if it
            were ever re-enabled an exported version would let other apps
            trigger proof generation against arbitrary URIs. Keep it
            unexported so a future un-comment doesn't reopen that surface.
        -->
        <receiver
            android:name=".service.CameraEventReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter android:priority="10000">
                <action android:name="com.android.camera.NEW_PICTURE" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter android:priority="10000">
                <action android:name="com.android.camera.NEW_VIDEO" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="video/*" />
            </intent-filter>
        </receiver>
        <!--
            ProofEventReceiver drives the in-app Activity feed across the whole
            capture lifecycle: MEDIA_CAPTURED (item appears immediately),
            PROOF_START (signing in progress), and PROOF_GENERATED[_IMPORT]
            (proof complete). The sole producers are the in-app camera and
            MediaWatcher.sendBroadcast(), which target us via setPackage().
            Exported, it lets another app forge feed entries with
            attacker-supplied URI + hash strings, which become phishing
            anchors in the user's own history view.
        -->
        <receiver
            android:name=".org.witness.proofmode.util.ProofEventReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter android:priority="10000">
                <action android:name="org.witness.proofmode.MEDIA_CAPTURED" />
            </intent-filter>
            <intent-filter android:priority="10000">
                <action android:name="org.witness.proofmode.PROOF_START" />
            </intent-filter>
            <intent-filter android:priority="10000">
                <action android:name="org.witness.proofmode.PROOF_GENERATED" />
            </intent-filter>
            <intent-filter android:priority="10000">
                <action android:name="org.witness.proofmode.PROOF_GENERATED_IMPORT" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            tools:node="remove"></provider>
    </application>

</manifest>